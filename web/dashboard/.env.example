# TrendStorm Dashboard — environment variables
# Copy to .env.local for local dev. Never commit .env.local.

# Auth0 application settings
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://api.trendstorm.ai

# API base URL — proxied via Vite in dev (defaults to localhost:8080 via vite.config.ts)
VITE_API_BASE_URL=http://localhost:8080
