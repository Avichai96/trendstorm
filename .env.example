# ==============================================================================
# TrendStorm AI — Environment Contract
# ==============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Every config knob the application reads must be declared here.
# Naming convention: {SUBSYSTEM}__{KEY} using DOUBLE underscores so
# Pydantic Settings can map them to nested models (e.g. mongo.uri).
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
APP__ENV=local                      # local | dev | staging | prod
APP__NAME=trendstorm
APP__LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
APP__LOG_FORMAT=json                # json (prod) | console (dev pretty)

# ------------------------------------------------------------------------------
# MongoDB
# ------------------------------------------------------------------------------
# Note: directConnection=true is REQUIRED for single-node replica sets.
# Without it, the driver tries to discover other replica set members and fails.
MONGO__URI=mongodb://root:rootpass@mongo:27017/?replicaSet=rs0&directConnection=true&authSource=admin
MONGO__DATABASE=trendstorm
MONGO__MAX_POOL_SIZE=100
MONGO__MIN_POOL_SIZE=10
MONGO__SERVER_SELECTION_TIMEOUT_MS=5000

# ------------------------------------------------------------------------------
# Kafka
# ------------------------------------------------------------------------------
KAFKA__BOOTSTRAP_SERVERS=kafka:9092
KAFKA__CLIENT_ID=trendstorm
KAFKA__CONSUMER_GROUP_PREFIX=trendstorm
KAFKA__SECURITY_PROTOCOL=PLAINTEXT   # PLAINTEXT (local) | SASL_SSL (prod)
KAFKA__SASL_MECHANISM=
KAFKA__SASL_USERNAME=
KAFKA__SASL_PASSWORD=

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS__URL=redis://redis:6379/0
REDIS__MAX_CONNECTIONS=50
REDIS__SEMANTIC_CACHE_TTL_SECONDS=3600
REDIS__SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.97

# ------------------------------------------------------------------------------
# Vector Store
# ------------------------------------------------------------------------------
VECTOR__PROVIDER=chroma             # chroma | pinecone
VECTOR__CHROMA_HOST=chroma
VECTOR__CHROMA_PORT=8000
VECTOR__COLLECTION_NAME=trendstorm_chunks
VECTOR__EMBEDDING_DIMENSIONS=1536

# ------------------------------------------------------------------------------
# Blob Storage (S3-compatible)
# ------------------------------------------------------------------------------
BLOB__ENDPOINT=http://minio:9000
BLOB__ACCESS_KEY=minioadmin
BLOB__SECRET_KEY=minioadmin
BLOB__BUCKET_RAW=trendstorm-raw
BLOB__BUCKET_REPORTS=trendstorm-reports
BLOB__REGION=us-east-1

# ------------------------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------------------------
LLM__DEFAULT_PROVIDER=anthropic     # anthropic | openai | ollama
LLM__ROUTING_STRATEGY=cost_aware    # cost_aware | quality_first | local_first

# Anthropic
LLM__ANTHROPIC_API_KEY=
LLM__ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI
LLM__OPENAI_API_KEY=
LLM__OPENAI_CHAT_MODEL=gpt-4o-mini
LLM__OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
LLM__OLLAMA_BASE_URL=http://ollama:11434
LLM__OLLAMA_DEFAULT_MODEL=llama3.2:3b
LLM__OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Cohere (rerank only)
LLM__COHERE_API_KEY=
LLM__COHERE_RERANK_MODEL=rerank-v3.5

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
OTEL__EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL__EXPORTER_OTLP_PROTOCOL=grpc
OTEL__SERVICE_NAME=trendstorm
OTEL__SERVICE_VERSION=0.1.0
OTEL__TRACES_SAMPLER=parentbased_traceidratio
OTEL__TRACES_SAMPLER_ARG=1.0        # 1.0 = sample everything (local). Prod: 0.1

# LangSmith (optional — leave blank to disable)
LANGSMITH__API_KEY=
LANGSMITH__PROJECT=trendstorm-local
LANGSMITH__TRACING=false            # true | false

# ------------------------------------------------------------------------------
# API
# ------------------------------------------------------------------------------
API__HOST=0.0.0.0
API__PORT=8000
API__WORKERS=1                      # uvicorn workers. Use 1 in dev, >1 in prod
API__CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API__SSE_HEARTBEAT_SECONDS=15

# ------------------------------------------------------------------------------
# HITL (Human-in-the-Loop) review queue — Phase 13.5
# ------------------------------------------------------------------------------
# Per-tenant settings live in the `tenant_settings` MongoDB collection.
# These env vars control system-wide defaults only.
HITL__DEFAULT_TIMEOUT_HOURS=48      # default SLA window for a pending review (1–720)
HITL__SWEEPER_INTERVAL_SECONDS=60   # how often the review-timeout sweeper polls (10–3600)


# ------------------------------------------------------------------------------
# Memory (Phase 15.5) — long-term episodic + semantic memory consolidation
# ------------------------------------------------------------------------------
MEMORY__EPISODIC_TTL_DAYS=730                  # retain episodic memories for 2 years
MEMORY__SEMANTIC_TTL_DAYS=730                  # retain semantic memories for 2 years
MEMORY__SUPERSEDE_SIMILARITY_THRESHOLD=0.92    # cosine sim above which old memory is superseded
MEMORY__MAX_SEMANTIC_MEMORIES_PER_JOB=10       # LLM extraction cap per analysis pass (cost control)
MEMORY__MEMORY_FINAL_K=5                       # memories injected into each Analyst context


# ------------------------------------------------------------------------------
# Dashboard (Phase 15a) — web/dashboard/.env.local for local dev
# These are read by Vite at build time as VITE_* variables.
# In production, values are injected via public/config.json (CDN/ConfigMap).
# ------------------------------------------------------------------------------
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
# VITE_AUTH0_AUDIENCE=https://api.trendstorm.ai
# VITE_API_BASE_URL=http://localhost:8080


# ------------------------------------------------------------------------------
# Auth0 (Phase 16) — identity provider for self-service auth & registration
# Two Auth0 applications required:
#   1. Regular Web App — end-user signup/login/OAuth flows
#   2. Machine-to-Machine (M2M) — Management API (password reset, email verify, delete)
# ------------------------------------------------------------------------------
AUTH0__DOMAIN=your-tenant.auth0.com
AUTH0__CLIENT_ID=your_auth0_regular_web_app_client_id
AUTH0__CLIENT_SECRET=your_auth0_regular_web_app_client_secret
AUTH0__AUDIENCE=https://your-tenant.auth0.com/api/v2/
AUTH0__MANAGEMENT_CLIENT_ID=your_auth0_m2m_client_id
AUTH0__MANAGEMENT_CLIENT_SECRET=your_auth0_m2m_client_secret
AUTH0__DATABASE_CONNECTION=Username-Password-Authentication  # Auth0 DB connection name


# ------------------------------------------------------------------------------
# Email (Phase 16) — transactional email delivery
# Provider: "postmark" for production, "dev" for local (in-memory inbox, no sends)
# ------------------------------------------------------------------------------
EMAIL__PROVIDER=dev                            # "dev" | "postmark"
EMAIL__POSTMARK_SERVER_TOKEN=your_postmark_server_token
EMAIL__FROM_EMAIL=no-reply@yourdomain.com
EMAIL__FROM_NAME=TrendStorm
EMAIL__APP_BASE_URL=http://localhost:8080      # used for email link generation


# ------------------------------------------------------------------------------
# JWT (Phase 16) — short-lived access token settings (our own HS256 JWTs)
# Use a 32+ byte random secret. Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
JWT__SECRET=change-me-in-production-use-32-plus-random-bytes
JWT__ALGORITHM=HS256
JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT__REFRESH_TOKEN_EXPIRE_DAYS=30


# ------------------------------------------------------------------------------
# Signup (Phase 16) — controls who can create new accounts
# signup_mode: "open" (anyone) | "invite_only" (default) | "closed" (no new signups)
# allowlist_domains: comma-separated list of email domains that bypass invite_only
# ------------------------------------------------------------------------------
SIGNUP__SIGNUP_MODE=invite_only
SIGNUP__ALLOWLIST_DOMAINS=                    # e.g. "yourdomain.com,partner.com"
SIGNUP__ACCOUNT_DELETION_GRACE_DAYS=30        # days between schedule_deletion and hard purge

