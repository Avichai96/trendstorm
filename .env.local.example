# ==============================================================================
# TrendStorm AI — Local overrides (host-side development)
# ==============================================================================
# Copy this file to .env.local (gitignored) when running the app or scripts
# directly on your machine (not inside Docker).
#
# These values override .env, pointing services at Docker's published ports
# instead of the Docker-internal hostnames (mongo, kafka, redis, …).
# ==============================================================================

MONGO__URI=mongodb://root:rootpass@localhost:27017/?directConnection=true&authSource=admin
KAFKA__BOOTSTRAP_SERVERS=localhost:29092
REDIS__URL=redis://localhost:6379/0
VECTOR__CHROMA_HOST=localhost
BLOB__ENDPOINT=http://localhost:9000
LLM__OLLAMA_BASE_URL=http://localhost:11434
OTEL__EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ------------------------------------------------------------------------------
# Phase 8 — Analyst worker API keys
# ------------------------------------------------------------------------------
# These flow into the analyst-worker container via docker-compose.app.yml.
# The analyst will fail to start if no chat-provider key is configured.
# Cohere is optional — RRF-only retrieval is the fallback when absent.
# ------------------------------------------------------------------------------
# LLM__ANTHROPIC_API_KEY=sk-ant-...
# LLM__COHERE_API_KEY=...
# LLM__OPENAI_API_KEY=sk-...
# GEMINI__API_KEY=...
