# ==============================================================================
# TrendStorm AI — Local overrides (host-side development)
# ==============================================================================
# Copy this file to .env.local (gitignored) when running the app or scripts
# directly on your machine (not inside Docker).
#
# These values override .env, pointing services at Docker's published ports
# instead of the Docker-internal hostnames (mongo, kafka, redis, …).
# ==============================================================================

MONGO__URI=mongodb://root:rootpass@localhost:27017/?directConnection=true&authSource=admin
KAFKA__BOOTSTRAP_SERVERS=localhost:29092
REDIS__URL=redis://localhost:6379/0
VECTOR__CHROMA_HOST=localhost
BLOB__ENDPOINT=http://localhost:9000
LLM__OLLAMA_BASE_URL=http://localhost:11434
OTEL__EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ------------------------------------------------------------------------------
# Phase 8 — Analyst worker API keys
# ------------------------------------------------------------------------------
# These flow into the analyst-worker container via docker-compose.app.yml.
# The analyst will fail to start if no chat-provider key is configured.
# Cohere is optional — RRF-only retrieval is the fallback when absent.
# ------------------------------------------------------------------------------
# LLM__ANTHROPIC_API_KEY=sk-ant-...
# LLM__COHERE_API_KEY=...
# LLM__OPENAI_API_KEY=sk-...
# GEMINI__API_KEY=...

# ------------------------------------------------------------------------------
# Phase 16 — Self-service auth (JWT, Auth0, email, signup policy)
# ------------------------------------------------------------------------------
# Required for the /v1/auth/* endpoints and the account_purge_worker.
# In dev mode, EMAIL__PROVIDER=dev (default) logs emails to stdout instead of
# sending via Postmark. AUTH0__* are only needed for OAuth flows; email/password
# auth works locally without them (AUTH_MODE=disabled in dev).
# ------------------------------------------------------------------------------

# JWT signing secret — must be ≥32 random bytes in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT__SECRET=change-me-dev-only-not-for-production

# JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

# Signup policy: open | invite_only | closed
# SIGNUP__SIGNUP_MODE=invite_only
# SIGNUP__ALLOWLIST_DOMAINS=yourcompany.com,partner.com

# GDPR purge grace period (days before hard-delete after schedule_deletion).
# SIGNUP__ACCOUNT_DELETION_GRACE_DAYS=30

# Auth0 — Regular Web Application (end-user flows: signup, login, OAuth)
# AUTH0__DOMAIN=my-tenant.us.auth0.com
# AUTH0__CLIENT_ID=...
# AUTH0__CLIENT_SECRET=...
# AUTH0__AUDIENCE=https://api.trendstorm.ai

# Auth0 — Machine-to-Machine application (Management API)
# Scopes required: read:users update:users delete:users create:users
# AUTH0__MANAGEMENT_CLIENT_ID=...
# AUTH0__MANAGEMENT_CLIENT_SECRET=...

# Email delivery (dev default logs to stdout; set postmark for real emails)
# EMAIL__PROVIDER=postmark
# EMAIL__POSTMARK_SERVER_TOKEN=...
# EMAIL__FROM_EMAIL=noreply@trendstorm.ai
# EMAIL__APP_BASE_URL=http://localhost:5173
